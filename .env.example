# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hiremind
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false
DB_MAX_CONNECTIONS=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=hiremind:

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ALGORITHM=HS256

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=hiremind-uploads
AWS_S3_UPLOAD_PATH=uploads/

# Email (SMTP)
# For Local Development: Use Mailpit (Docker service)
# Start with: docker-compose -f docker/docker-compose.yml up -d mailpit
# Web UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hiremind.com
SMTP_FROM_NAME=Hire Mind

# For Production: Use Gmail, SendGrid, AWS SES, or other SMTP service
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-email-app-password
# SMTP_FROM=noreply@hiremind.com
# SMTP_FROM_NAME=Hire Mind

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,PATCH,DELETE

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15m

# Logging
LOG_LEVEL=info
